{
  "targets": [
    {
      "name": "build-image",
      "command": "echo 'image built'"
    },
    {
      "name": "compile",
      "command": "echo compiled > output.txt",
      "outputs": ["output.txt"],
      "environment": ":docker-env"
    }
  ],
  "environments": [
    {
      "name": "docker-env",
      "type": "docker",
      "dependencies": [":build-image"],
      "docker_image": "alpine:latest"
    }
  ]
}
